#include <16f877a.h>
#device ADC=8
#use delay(clock=4M)
#use fast_io(a)
#use fast_io(b)
#use fast_io(c)

#define use_portb_lcd TRUE
#include <lcd.c>

unsigned int8 deger; 
float voltaj;

void main()
{
   setup_psp(PSP_DISABLED);
   setup_timer_1(T1_DISABLED);
   setup_CCP2(CCP_OFF);
   
   // PWM Ayarlar²
   setup_timer_2(T2_DIV_BY_4, 255, 1); 
   setup_CCP1(CCP_PWM);
   
   // ADC Ayarlar²
   setup_adc(adc_clock_div_32);
   setup_adc_ports(ALL_ANALOG);
   
   // 7. pini (RA5) sildik, varsay²lan olarak AN0 (2. pin) kanal²n² seþtik.
   set_adc_channel(0); 
   
   set_tris_a(0xFF); // T³m A portunu giri■ yapt²k (G³venli mod)
   set_tris_b(0x00);
   set_tris_c(0x00);
   
   output_c(0x00);
   lcd_init();
   
   printf(lcd_putc,"\fDC Motor\nKontrol Hazir");
   delay_ms(1000);
   
   set_pwm1_duty(0);
   
   // Motor Y÷n³
   output_high(pin_c3);
   output_low(pin_c4);

   while(TRUE)
   {
      deger = read_adc(); // Art²k AN0 (2. pin) okunuyor
      
      voltaj = (float)deger / 51.0;
      set_pwm1_duty(deger);
      
      printf(lcd_putc,"\fV=%1.2f V", voltaj);
      lcd_gotoxy(1,2);
      printf(lcd_putc,"PWM Deger=%u", deger);
      
      delay_ms(100); 
   }
}
