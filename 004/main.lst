006B:  MOVF   78,W
006C:  MOVWF  2F
006D:  BTFSC  2F.7
006E:  GOTO   06A
....................    lcd_output_rs(address); 
006F:  BTFSS  2D.0
0070:  BCF    08.1
0071:  BTFSC  2D.0
0072:  BSF    08.1
....................    delay_cycles(1); 
0073:  NOP
....................    lcd_output_rw(0); 
0074:  BCF    08.2
....................    delay_cycles(1); 
0075:  NOP
....................    lcd_output_enable(0); 
0076:  BCF    08.0
....................    lcd_send_nibble(n >> 4); 
0077:  SWAPF  2E,W
0078:  MOVWF  2F
0079:  MOVLW  0F
007A:  ANDWF  2F,F
007B:  MOVF   2F,W
007C:  MOVWF  30
007D:  CALL   030
....................    lcd_send_nibble(n & 0xf); 
007E:  MOVF   2E,W
007F:  ANDLW  0F
0080:  MOVWF  2F
0081:  MOVWF  30
0082:  CALL   030
0083:  RETURN
.................... } 
