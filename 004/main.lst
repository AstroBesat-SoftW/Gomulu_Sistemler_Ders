00A1:  MOVWF  30
00A2:  CALL   030
....................    delay_ms(5); 
00A3:  MOVLW  05
00A4:  MOVWF  29
00A5:  CALL   01B
....................    for(i=0;i<=3;++i) 
00A6:  CLRF   22
00A7:  MOVF   22,W
00A8:  SUBLW  03
00A9:  BTFSS  03.0
00AA:  GOTO   0B4
....................       lcd_send_byte(0,LCD_INIT_STRING[i]); 
00AB:  MOVF   22,W
00AC:  CALL   004
00AD:  MOVWF  23
00AE:  CLRF   2D
