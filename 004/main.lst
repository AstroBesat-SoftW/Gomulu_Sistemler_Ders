....................  
....................   #if defined(LCD_EXTENDED_NEWLINE) 
00B2:  INCF   22,F
00B3:  GOTO   0A7
00B4:  BCF    0A.3
00B5:  BCF    0A.4
00B6:  GOTO   1D0 (RETURN)
....................    g_LcdX = 0; 
....................    g_LcdY = 0; 
....................   #endif 
.................... } 
....................  
.................... void lcd_gotoxy(unsigned int8 x, unsigned int8 y) 
.................... { 
....................    unsigned int8 address; 
....................     
....................    if(y!=1) 
00B7:  DECFSZ 2A,W
00B8:  GOTO   0BA
00B9:  GOTO   0BD
....................       address=LCD_LINE_TWO; 
00BA:  MOVLW  40
00BB:  MOVWF  2B
00BC:  GOTO   0BE
....................    else 
....................       address=0; 
00BD:  CLRF   2B
....................       
....................    address+=x-1; 
00BE:  MOVLW  01
00BF:  SUBWF  29,W
00C0:  ADDWF  2B,F
....................    lcd_send_byte(0,0x80|address); 
00C1:  MOVF   2B,W
00C2:  IORLW  80
00C3:  MOVWF  2C
00C4:  CLRF   2D
00C5:  MOVF   2C,W
00C6:  MOVWF  2E
00C7:  CALL   064
....................  
....................   #if defined(LCD_EXTENDED_NEWLINE) 
00C8:  RETURN
....................    g_LcdX = x - 1; 
....................    g_LcdY = y - 1; 
....................   #endif 
.................... } 
