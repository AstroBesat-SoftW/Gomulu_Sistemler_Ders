00E2:  CALL   01B
....................                     #if defined(LCD_EXTENDED_NEWLINE) 
....................                      g_LcdX = 0; 
....................                      g_LcdY = 0; 
....................                     #endif 
....................                      break; 
00E3:  GOTO   0F4
....................  
....................      #if defined(LCD_EXTENDED_NEWLINE) 
....................       case '\r'   :  lcd_gotoxy(1, g_LcdY+1);   break; 
....................       case '\n'   : 
....................          while (g_LcdX++ < LCD_LINE_LENGTH) 
....................          { 
....................             lcd_send_byte(1, ' '); 
....................          } 
....................          lcd_gotoxy(1, g_LcdY+2); 
....................          break; 
....................      #else 
....................       case '\n'   : lcd_gotoxy(1,2);        break; 
00E4:  MOVLW  01
00E5:  MOVWF  29
00E6:  MOVLW  02
00E7:  MOVWF  2A
00E8:  CALL   0B7
00E9:  GOTO   0F4
....................      #endif 
....................       
....................       case '\b'   : lcd_send_byte(0,0x10);  break; 
00EA:  CLRF   2D
00EB:  MOVLW  10
00EC:  MOVWF  2E
00ED:  CALL   064
00EE:  GOTO   0F4
....................       
....................      #if defined(LCD_EXTENDED_NEWLINE) 
....................       default     :  
....................          if (g_LcdX < LCD_LINE_LENGTH) 
....................          { 
....................             lcd_send_byte(1, c); 
....................             g_LcdX++; 
....................          } 
....................          break; 
....................      #else 
....................       default     : lcd_send_byte(1,c);     break; 
00EF:  MOVLW  01
00F0:  MOVWF  2D
00F1:  MOVF   28,W
00F2:  MOVWF  2E
00F3:  CALL   064
....................      #endif 
....................    } 
00F4:  RETURN
.................... } 
