....................    lcd_rs_tris(); 
0089:  BCF    08.1
....................    lcd_rw_tris(); 
008A:  BCF    08.2
....................  #endif 
....................  
....................    lcd_output_rs(0); 
008B:  BCF    03.5
008C:  BCF    08.1
....................    lcd_output_rw(0); 
008D:  BCF    08.2
....................    lcd_output_enable(0); 
008E:  BCF    08.0
....................      
....................    delay_ms(15); 
