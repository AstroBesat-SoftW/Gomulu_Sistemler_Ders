0066:  BCF    08.1
....................    lcd_rw_tris(); 
0067:  BCF    08.2
....................   #endif 
....................  
....................    lcd_output_rs(0); 
0068:  BCF    03.5
0069:  BCF    08.1
....................    while ( bit_test(lcd_read_byte(),7) ) ; 
