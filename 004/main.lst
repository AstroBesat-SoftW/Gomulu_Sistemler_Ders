.................... void lcd_putc(char c) 
.................... { 
....................    switch (c) 
00C9:  MOVF   28,W
00CA:  XORLW  07
00CB:  BTFSC  03.2
00CC:  GOTO   0D7
00CD:  XORLW  0B
00CE:  BTFSC  03.2
00CF:  GOTO   0DC
