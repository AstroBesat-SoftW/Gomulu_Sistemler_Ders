#include <main.h>

// Denetleyici Konfigürasyonu
#fuses XT, NOWDT, NOPROTECT, NOBROWNOUT, NOLVP, NOPUT, NOWRT, NODEBUG
#use delay(clock=4M)

// LCD Ayarlarę
// #define use_portb_lcd TRUE // Port D kullandęđęmęz için bu ifadeye gerek yok
#include <lcd.c>

// Global Deđițkenler
char z;
int i = 5;

void main() 
{
    // LCD Bațlatma ve Ęlk Temizlik
    lcd_init();
    printf(lcd_putc, "\f"); // Ekranę temizle
    
    // Ęlk Mesajlar
    printf(lcd_putc, "DENEME");
    printf(lcd_putc, "\nTEST");
    delay_ms(1000);
    
    // Deđițken Yazdęrma (i)
    printf(lcd_putc, "\f");
    printf(lcd_putc, "i=%d", i);
    delay_ms(1000);
    
    // Karakter Okuma ve Konumlandęrma
    printf(lcd_putc, "\f");
    lcd_gotoxy(3, 1);
    printf(lcd_putc, "Hosgeldiniz");
    
    z = lcd_getc(6, 1); // 6. sütun 1. satęrdaki karakteri al ('g' karakterine denk gelir)
    
    delay_ms(1000);
    
    // Okunan Karakteri Yazdęrma
    printf(lcd_putc, "\f");
    printf(lcd_putc, "z=%c", z);
    
    while(TRUE); // Programęn bitip bața dönmemesi için sonsuz döngü (opsiyonel)
}
